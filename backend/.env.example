# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
PYTHON_CMD=python

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://coder-v.vercel.app

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (including -----BEGIN/END----- lines).
# On Render: use the `private_key` string from the service account JSON (with \n for newlines),
# and do not wrap the value in extra quotes in the dashboard (or normalization will strip one pair).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional — avoids PEM mangling: base64-encode the full service account JSON (one line) and set only this on Render.
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OpenAI (Quiz AI Bot) ──────────────────────────────────────────────────────
# Get an API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
# Optional — defaults to gpt-4o-mini (fast & cheap, works great for hints)
# OPENAI_MODEL=gpt-4o-mini

# ── Email (Gmail SMTP — used for password reset emails) ──────────────────────
# 1. Enable 2-Step Verification on the Google account:
#    https://myaccount.google.com/security
# 2. Create an App Password (type: Mail) at:
#    https://myaccount.google.com/apppasswords
# 3. Use that 16-char password below (NOT your normal Gmail password).
MAIL_USER=your-gmail-address@gmail.com
MAIL_PASS=your-16-char-app-password
# Optional — From: header shown in the email client.
# MAIL_FROM=CoderV <your-gmail-address@gmail.com>

# Public URL of the deployed frontend. Used to build reset links in emails.
FRONTEND_URL=http://localhost:5173
