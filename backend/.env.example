# ════════════════════════════════════════════════════════════════════════════
# backend/.env  ← gitignored, local secrets only
# On Render:    set all of these in Render dashboard → Environment
# ════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
# Local: 5000   |   Render: leave blank (Render injects PORT automatically)
PORT=5000

# ── Python ───────────────────────────────────────────────────────────────────
# Local (Windows): python   |   Render (Linux): python3
PYTHON_CMD=python

# ── Clerk ────────────────────────────────────────────────────────────────────
# Secret key — Clerk dashboard → API Keys → Secret key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Webhook signing secret — Clerk dashboard → Webhooks → your endpoint → Signing Secret
# Add webhook URL: https://coderv-backend.onrender.com/api/webhooks/clerk
# Subscribe to events: user.created  user.updated  user.deleted
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ── Supabase (service role — server-side only, bypasses RLS) ─────────────────
# Get from: Supabase dashboard → Settings → API → service_role (secret)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Include both: production Vercel URL + localhost for local frontend dev
ALLOWED_ORIGINS=https://coder-v.vercel.app,http://localhost:5173
