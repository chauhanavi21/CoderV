# Copy this file to .env and fill in values

# Port the Express server listens on
PORT=5000

# Python executable — change if 'python' is not on your PATH
# Windows example: PYTHON_CMD=python
# Linux/Mac example: PYTHON_CMD=python3
# Full path example: PYTHON_CMD=C:\Python312\python.exe
PYTHON_CMD=python

# Comma-separated list of allowed frontend origins (for CORS)
ALLOWED_ORIGINS=http://localhost:5173
