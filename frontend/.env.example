# ════════════════════════════════════════════════════════════════════════════
# frontend/.env        ← committed to git, safe (no secrets)
# frontend/.env.local  ← gitignored, put your secrets here
# ════════════════════════════════════════════════════════════════════════════

# ── COMMITTED in frontend/.env (same for local AND production) ──────────────
# No need to change this — the Render backend is always used.
VITE_API_URL=https://coderv-backend.onrender.com

# ── LOCAL ONLY — put these in frontend/.env.local (never commit) ─────────────
# On Vercel: add these in dashboard → Project → Settings → Environment Variables

# Clerk publishable key
# Dev key:  https://dashboard.clerk.com → API Keys
# Prod key: use a separate Clerk production instance
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Supabase (anon / publishable key — safe for frontend use)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here
